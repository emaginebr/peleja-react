{
  "name": "peleja-react",
  "version": "0.1.0",
  "description": "React comments widget for Peleja",
  "type": "module",
  "main": "dist/peleja-react.cjs",
  "module": "dist/peleja-react.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/peleja-react.js",
      "require": "./dist/peleja-react.cjs"
    },
    "./style.css": "./dist/peleja-react.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext .ts,.tsx",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "nauth-react": "^0.2.0",
    "i18next": "^25.0.0",
    "react-i18next": "^15.0.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.0",
    "emoji-picker-react": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "license": "MIT"
}
